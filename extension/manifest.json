{
  "manifest_version": 3,
  "name": "JAT 13",
  "version": "13.0.2",
  "description": "JAT 13 — thin hands & eyes for the desktop brain. Sensor snapshots up, actuator commands down. No apply logic lives here.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "webNavigation",
    "downloads"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://boards.greenhouse.io/*",
    "*://jobs.lever.co/*",
    "*://jobs.ashbyhq.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_title": "JAT 13",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://smartapply.indeed.com/*",
        "*://boards.greenhouse.io/*",
        "*://jobs.lever.co/*",
        "*://jobs.ashbyhq.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
